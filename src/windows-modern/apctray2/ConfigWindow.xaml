<Window x:Class="apctray2.ConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configurações" Height="540" Width="540"
        MinHeight="500" MinWidth="480"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        FontFamily="{StaticResource AppFont}">

  <Border Background="{StaticResource BgBaseBrush}" 
          CornerRadius="16" 
          BorderBrush="{StaticResource BorderSubtleBrush}" 
          BorderThickness="1">
    <Border.Effect>
      <DropShadowEffect Color="#000000" Direction="270" ShadowDepth="3" Opacity="0.5" BlurRadius="16"/>
    </Border.Effect>
    
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="40"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>

      <!-- Title Bar -->
      <Grid Grid.Row="0" Background="Transparent" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
        <StackPanel Orientation="Horizontal" Margin="16,0,0,0" VerticalAlignment="Center">
          <Ellipse Width="8" Height="8" Fill="{StaticResource GreenBrush}" Margin="0,0,8,0"/>
          <TextBlock Text="Configurações" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,8,0">
          <Button Content="&#x2500;" Style="{StaticResource TitleBarButton}" Click="Minimize_Click" FontFamily="Segoe UI" FontSize="14"/>
          <Button Content="&#x2715;" Style="{StaticResource CloseButton}" Click="CloseWindow_Click" FontFamily="Segoe UI" FontSize="12" Margin="4,0,0,0"/>
        </StackPanel>
      </Grid>

      <!-- Content -->
      <TabControl Grid.Row="1" Margin="12,0,12,12">
        <!-- Limits Tab -->
        <TabItem Header="&#x1F4D0; Limites">
          <ScrollViewer>
            <StackPanel Margin="16">
              <TextBlock Text="Atualização" FontWeight="Bold" Margin="0,0,0,10" Foreground="{StaticResource TextPrimaryBrush}"/>
              <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="120"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Intervalo (s):" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}"/>
                <TextBox x:Name="RefreshBox" Grid.Column="1"/>
              </Grid>

              <TextBlock Text="Tensão (V)" FontWeight="Bold" Margin="0,0,0,10" Foreground="{StaticResource TextPrimaryBrush}"/>
              <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="80"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="16"/>
                  <ColumnDefinition Width="80"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Mínimo:" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}"/>
                <TextBox x:Name="MinVoltBox" Grid.Column="1"/>
                <TextBlock Grid.Column="3" Text="Máximo:" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}"/>
                <TextBox x:Name="MaxVoltBox" Grid.Column="4"/>
              </Grid>

              <TextBlock Text="Frequência (Hz)" FontWeight="Bold" Margin="0,0,0,10" Foreground="{StaticResource TextPrimaryBrush}"/>
              <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="80"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="16"/>
                  <ColumnDefinition Width="80"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Mínimo:" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}"/>
                <TextBox x:Name="MinFreqBox" Grid.Column="1"/>
                <TextBlock Grid.Column="3" Text="Máximo:" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}"/>
                <TextBox x:Name="MaxFreqBox" Grid.Column="4"/>
              </Grid>

              <TextBlock Text="Bateria" FontWeight="Bold" Margin="0,0,0,10" Foreground="{StaticResource TextPrimaryBrush}"/>
              <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="100"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="16"/>
                  <ColumnDefinition Width="120"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Tensão (V):" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}"/>
                <TextBox x:Name="BattVoltBox" Grid.Column="1"/>
                <TextBlock Grid.Column="3" Text="Capacidade (Ah):" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}"/>
                <TextBox x:Name="BattCapBox" Grid.Column="4"/>
              </Grid>

              <TextBlock Text="Fator de Potência" FontWeight="Bold" Margin="0,0,0,10" Foreground="{StaticResource TextPrimaryBrush}"/>
              <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="80"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="PF (0-1):" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}"/>
                <TextBox x:Name="PowerFactorBox" Grid.Column="1"/>
              </Grid>
            </StackPanel>
          </ScrollViewer>
        </TabItem>
        
        <!-- Telegram Tab -->
        <TabItem Header="&#x1F4F1; Telegram">
          <StackPanel Margin="16">
            <CheckBox x:Name="TelegramEnableBox" Content="Ativar notificações Telegram" Margin="0,0,0,16"/>
            
            <TextBlock Text="Bot Token:" Margin="0,0,0,6" Foreground="{StaticResource TextSecondaryBrush}"/>
            <TextBox x:Name="BotTokenBox" Margin="0,0,0,16"/>
            
            <TextBlock Text="Chat ID:" Margin="0,0,0,6" Foreground="{StaticResource TextSecondaryBrush}"/>
            <TextBox x:Name="ChatIdBox" Margin="0,0,0,16"/>
            
            <TextBlock Text="Horário do log diário:" Margin="0,0,0,6" Foreground="{StaticResource TextSecondaryBrush}"/>
            <TextBox x:Name="DailyLogHourBox" Margin="0,0,0,16"/>
            
            <Button Content="Enviar mensagem de teste" Click="TestTelegram_Click" Style="{StaticResource AccentButton}" HorizontalAlignment="Left"/>
          </StackPanel>
        </TabItem>
      </TabControl>
    </Grid>
  </Border>
</Window>
