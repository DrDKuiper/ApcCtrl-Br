<Window x:Class="apctray2.PortDetectWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Detectar Nobreak (COM)" Height="380" Width="560"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        FontFamily="{StaticResource AppFont}">

  <Border Background="{StaticResource BgBaseBrush}" 
          CornerRadius="16" 
          BorderBrush="{StaticResource BorderSubtleBrush}" 
          BorderThickness="1">
    <Border.Effect>
      <DropShadowEffect Color="#000000" Direction="270" ShadowDepth="3" Opacity="0.5" BlurRadius="16"/>
    </Border.Effect>
    
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="40"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>

      <!-- Title Bar -->
      <Grid Grid.Row="0" Background="Transparent" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
        <StackPanel Orientation="Horizontal" Margin="16,0,0,0" VerticalAlignment="Center">
          <Ellipse Width="8" Height="8" Fill="{StaticResource CyanBrush}" Margin="0,0,8,0"/>
          <TextBlock Text="Detectar Nobreak (COM)" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,8,0">
          <Button Content="&#x2500;" Style="{StaticResource TitleBarButton}" Click="Minimize_Click" FontFamily="Segoe UI" FontSize="14"/>
          <Button Content="&#x2715;" Style="{StaticResource CloseButton}" Click="Close_Click" FontFamily="Segoe UI" FontSize="12" Margin="4,0,0,0"/>
        </StackPanel>
      </Grid>

      <!-- Content -->
      <Grid Grid.Row="1" Margin="16,4,16,16">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Portas seriais detectadas:" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>

        <Border Grid.Row="1" CornerRadius="8" BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1" ClipToBounds="True" Margin="0,0,0,8">
          <ListView x:Name="PortsList" SelectionMode="Single"
                    Background="Transparent" BorderThickness="0">
            <ListView.View>
              <GridView>
                <GridViewColumn Header="Porta" Width="80" DisplayMemberBinding="{Binding Port}"/>
                <GridViewColumn Header="Nome" Width="300" DisplayMemberBinding="{Binding FriendlyName}"/>
                <GridViewColumn Header="Fabricante" Width="120" DisplayMemberBinding="{Binding Manufacturer}"/>
              </GridView>
            </ListView.View>
          </ListView>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
          <Button Content="Atualizar" Click="Refresh_Click" Margin="0,0,8,0" Style="{StaticResource AccentButton}"/>
          <Button Content="Copiar sugestao" Click="CopySuggestion_Click" Margin="0,0,8,0" Style="{StaticResource ModernButton}"/>
          <Button Content="Fechar" Click="Close_Click" Style="{StaticResource ModernButton}"/>
        </StackPanel>
      </Grid>
    </Grid>
  </Border>
</Window>
