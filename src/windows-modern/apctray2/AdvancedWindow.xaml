<Window x:Class="apctray2.AdvancedWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:apctray2"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        Title="apcctrl - Dashboard Avançado" Height="840" Width="1200"
        MinHeight="840" MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        FontFamily="{StaticResource AppFont}">

  <Border Background="{StaticResource BgBaseBrush}" 
          CornerRadius="16" 
          BorderBrush="{StaticResource BorderSubtleBrush}" 
          BorderThickness="1">
    <Border.Effect>
      <DropShadowEffect Color="#000000" Direction="270" ShadowDepth="3" Opacity="0.5" BlurRadius="16"/>
    </Border.Effect>
    
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="40"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>

      <!-- Title Bar -->
      <Grid Grid.Row="0" Background="Transparent" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
        <StackPanel Orientation="Horizontal" Margin="16,0,0,0" VerticalAlignment="Center">
          <Ellipse Width="8" Height="8" Fill="{StaticResource CyanBrush}" Margin="0,0,8,0"/>
          <TextBlock Text="apcctrl" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
          <TextBlock Text="  Dashboard Avançado" FontSize="12" Foreground="{StaticResource TextMutedBrush}"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,8,0">
          <Button Content="&#x2500;" Style="{StaticResource TitleBarButton}" Click="Minimize_Click" FontFamily="Segoe UI" FontSize="14"/>
          <Button Content="&#x2715;" Style="{StaticResource CloseButton}" Click="CloseWindow_Click" FontFamily="Segoe UI" FontSize="12" Margin="4,0,0,0"/>
        </StackPanel>
      </Grid>

      <!-- Content -->
      <Grid Grid.Row="1" Margin="16,4,16,16">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header with mode indicator -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
          <StackPanel Orientation="Horizontal">
            <Border CornerRadius="10" Width="44" Height="44" Margin="0,0,12,0">
              <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                  <GradientStop Color="#22D3EE" Offset="0"/>
                  <GradientStop Color="#3B82F6" Offset="1"/>
                </LinearGradientBrush>
              </Border.Background>
              <TextBlock Text="&#x26A1;" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <StackPanel VerticalAlignment="Center">
              <TextBlock Text="{Binding UpsProfileName}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
              <TextBlock Text="{Binding UpsDeviceName}" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
              <TextBlock Text="{Binding StatusFriendly}" FontSize="12" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold"/>
              <TextBlock Text="{Binding Status}" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
            </StackPanel>
          </StackPanel>
          
          <!-- Mode Badge -->
          <Border x:Name="ModeIndicator" HorizontalAlignment="Right" 
                  Background="{StaticResource GreenBrush}" CornerRadius="14" Padding="16,8">
            <StackPanel>
              <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="ModeIcon" Text="&#x1F50C;" FontSize="16" Margin="0,0,8,0"/>
                <TextBlock x:Name="ModeText" Text="MODO REDE" FontSize="14" FontWeight="Bold" Foreground="White"/>
              </StackPanel>
              <TextBlock x:Name="ModeSubText" Text="Atualizando..." FontSize="11" Foreground="#FFFFFFCC" Margin="0,2,0,0"/>
            </StackPanel>
          </Border>
        </Grid>

        <!-- Quick Stats Row -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>

          <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,4,0">
            <StackPanel>
              <TextBlock Text="Fonte de Energia" Style="{StaticResource MetricLabelStyle}"/>
              <TextBlock Text="{Binding PowerSourceText}" Style="{StaticResource MetricValueStyle}"/>
            </StackPanel>
          </Border>

          <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="4,0,4,0">
            <StackPanel>
              <TextBlock Text="Última Atualização" Style="{StaticResource MetricLabelStyle}"/>
              <TextBlock Text="{Binding LastUpdateText}" Style="{StaticResource MetricValueStyle}"/>
            </StackPanel>
          </Border>

          <Border Grid.Column="2" Style="{StaticResource CardStyle}" Margin="4,0,0,0">
            <StackPanel>
              <TextBlock Text="Qualidade Elétrica" Style="{StaticResource MetricLabelStyle}"/>
              <TextBlock Text="{Binding VoltageStatus}" Style="{StaticResource MetricValueStyle}" Foreground="{Binding VoltageStatusBrush}"/>
            </StackPanel>
          </Border>
        </Grid>

        <!-- Tabs -->
        <TabControl Grid.Row="2">
          <!-- Status Dashboard Tab -->
          <TabItem Header="&#x1F4CA; Dashboard">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
              <Grid Margin="8">
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- Energy Flow -->
                <local:EnergyFlowControl x:Name="EnergyFlowDash" Grid.Row="0" Margin="6,6,6,12"/>
                
                <!-- Main Metrics -->
                <Grid Grid.Row="1">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                  </Grid.ColumnDefinitions>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                  </Grid.RowDefinitions>
                  
                  <!-- Battery -->
                  <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource CardStyle}">
                    <StackPanel>
                      <TextBlock Text="BATERIA" Style="{StaticResource CardTitleStyle}"/>
                      <Grid Margin="0,4,0,8">
                        <ProgressBar Minimum="0" Maximum="100" Height="32"
                                     Value="{Binding BatteryPercent}"
                                     Foreground="{StaticResource GreenBrush}"/>
                        <TextBlock Text="{Binding BatteryPercent, StringFormat='{}{0}%'}" 
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   FontWeight="Bold" FontSize="14" Foreground="White"/>
                      </Grid>
                      <StackPanel Margin="0,8,0,0">
                        <TextBlock Text="Saúde da bateria" Style="{StaticResource MetricLabelStyle}"/>
                        <TextBlock Text="{Binding BatteryHealthText}" FontSize="18" FontWeight="Bold" Foreground="{Binding BatteryHealthBrush}"/>
                        <TextBlock Text="{Binding BatteryHealthDetails}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                      </StackPanel>
                    </StackPanel>
                  </Border>
                  
                  <!-- Load -->
                  <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource CardStyle}">
                    <StackPanel>
                      <TextBlock Text="CARGA" Style="{StaticResource CardTitleStyle}"/>
                      <Grid Margin="0,4,0,8">
                        <ProgressBar Minimum="0" Maximum="100" Height="32"
                                     Value="{Binding LoadPercent}"
                                     Foreground="{StaticResource AmberBrush}"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                          <TextBlock Text="{Binding LoadPercent, StringFormat='{}{0}%'}" 
                                     FontWeight="Bold" FontSize="14" Foreground="White" Margin="0,0,6,0"/>
                          <TextBlock Text="{Binding LoadWatts}" FontWeight="Bold" FontSize="14" Foreground="#FFFFFF99"/>
                        </StackPanel>
                      </Grid>
                    </StackPanel>
                  </Border>
                  
                  <!-- Input Voltage -->
                  <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource CardStyle}">
                    <StackPanel>
                      <TextBlock Text="TENSÃO ENTRADA" Style="{StaticResource MetricLabelStyle}"/>
                      <TextBlock Text="{Binding InputVoltage}" FontSize="32" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                      <TextBlock Text="{Binding LineFreq}" FontSize="12" Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                  </Border>
                  
                  <!-- Output Voltage -->
                  <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource CardStyle}">
                    <StackPanel>
                      <TextBlock Text="TENSÃO SAÍDA" Style="{StaticResource MetricLabelStyle}"/>
                      <TextBlock Text="{Binding OutputVoltage}" FontSize="32" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                      <TextBlock Text="{Binding Temperature}" FontSize="12" Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                  </Border>
                </Grid>
              </Grid>
            </ScrollViewer>
          </TabItem>
          
          <!-- Charts Tab -->
          <TabItem Header="&#x1F4C8; Gráficos">
            <Grid Background="Transparent" Margin="8">
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
              </Grid.RowDefinitions>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>

              <!-- Range Controls -->
              <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="8" HorizontalAlignment="Right">
                <TextBlock Text="📅 Range:" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,8,0"/>
                <ComboBox x:Name="RangeComboBox" Width="130" Height="32" SelectedIndex="0" SelectionChanged="RangeComboBox_SelectionChanged"
                          Background="{StaticResource BgInputBrush}"
                          Foreground="{StaticResource TextPrimaryBrush}"
                          BorderBrush="{StaticResource BorderSubtleBrush}">
                  <ComboBoxItem Content="1 hora"/>
                  <ComboBoxItem Content="6 horas"/>
                  <ComboBoxItem Content="24 horas"/>
                  <ComboBoxItem Content="Personalizado"/>
                </ComboBox>
                <DatePicker x:Name="StartDatePicker" Width="130" Height="32" Margin="8,0,4,0" Visibility="Collapsed" SelectedDateChanged="CustomRange_Changed"
                            Background="{StaticResource BgInputBrush}"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            BorderBrush="{StaticResource BorderSubtleBrush}"/>
                <TextBlock Text="até" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" Margin="4,0" Visibility="Collapsed" x:Name="DateSeparator"/>
                <DatePicker x:Name="EndDatePicker" Width="130" Height="32" Margin="4,0,0,0" Visibility="Collapsed" SelectedDateChanged="CustomRange_Changed"
                            Background="{StaticResource BgInputBrush}"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            BorderBrush="{StaticResource BorderSubtleBrush}"/>
              </StackPanel>

              <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource CardStyle}">
                <StackPanel>
                  <TextBlock Text="Carga da Bateria (%)" Style="{StaticResource CardTitleStyle}"/>
                  <lvc:CartesianChart x:Name="BatteryChart" Height="200"/>
                </StackPanel>
              </Border>

              <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource CardStyle}">
                <StackPanel>
                  <TextBlock Text="Carga do UPS (%)" Style="{StaticResource CardTitleStyle}"/>
                  <lvc:CartesianChart x:Name="LoadChart" Height="200"/>
                </StackPanel>
              </Border>

              <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource CardStyle}">
                <StackPanel>
                  <TextBlock Text="Tensão (V)" Style="{StaticResource CardTitleStyle}"/>
                  <lvc:CartesianChart x:Name="VoltageChart" Height="200"/>
                </StackPanel>
              </Border>

              <Border Grid.Row="2" Grid.Column="1" Style="{StaticResource CardStyle}">
                <StackPanel>
                  <TextBlock Text="Consumo (W)" Style="{StaticResource CardTitleStyle}"/>
                  <lvc:CartesianChart x:Name="WattsChart" Height="200"/>
                </StackPanel>
              </Border>
            </Grid>
          </TabItem>

          <!-- Log Tab -->
          <TabItem Header="&#x1F4CB; Log de Eventos">
            <Border Style="{StaticResource CardStyle}" Margin="8">
              <Grid>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="*"/>
                  <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <TextBlock Grid.Row="0" Text="Eventos Recentes" Style="{StaticResource CardTitleStyle}"/>
                
                <ListBox x:Name="LogList" Grid.Row="1" 
                         FontFamily="Consolas"
                         FontSize="11"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                  <Button Content="&#x21BB; Atualizar" Style="{StaticResource ModernButton}" Margin="0,0,8,0"/>
                  <Button Content="&#x2715; Limpar" Click="ClearLogs_Click" Style="{StaticResource ModernButton}"/>
                </StackPanel>
              </Grid>
            </Border>
          </TabItem>

          <!-- Technical Info Tab -->
          <TabItem Header="&#x1F527; Dados Técnicos">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
              <StackPanel Margin="8">
                <!-- UPS Status Overview -->
                <Border Style="{StaticResource CardStyle}">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                      <RowDefinition Height="Auto"/>
                      <RowDefinition Height="Auto"/>
                      <RowDefinition Height="Auto"/>
                      <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Grid.ColumnSpan="3" Text="📊 Status e Operação" 
                               FontSize="15" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>
                    
                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,16,12">
                      <TextBlock Text="NOME DO PERFIL" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4"/>
                      <TextBlock Text="{Binding UpsProfileName}" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,16,12">
                      <TextBlock Text="STATUS DA OPERAÇÃO" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4"/>
                      <TextBlock Text="{Binding StatusFriendly}" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource CyanBrush}"/>
                      <TextBlock Text="{Binding Status}" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,12">
                      <TextBlock Text="AUTONOMIA RESTANTE" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4"/>
                      <TextBlock Text="{Binding TimeLeft}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource GreenBrush}"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,16,12">
                      <TextBlock Text="CARGA DA BATERIA" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4"/>
                      <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding BatteryPercent, StringFormat='{}{0}'}" FontSize="28" Foreground="{StaticResource GreenBrush}" FontWeight="Bold"/>
                        <TextBlock Text="%" FontSize="16" Foreground="{StaticResource GreenBrush}" FontWeight="SemiBold" VerticalAlignment="Bottom" Margin="2,0,0,6"/>
                      </StackPanel>
                    </StackPanel>
                    
                    <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,0,16,12">
                      <TextBlock Text="CARGA DO SISTEMA" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4"/>
                      <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding LoadPercent, StringFormat='{}{0}'}" FontSize="28" Foreground="{StaticResource AmberBrush}" FontWeight="Bold"/>
                        <TextBlock Text="%" FontSize="16" Foreground="{StaticResource AmberBrush}" FontWeight="SemiBold" VerticalAlignment="Bottom" Margin="2,0,8,6"/>
                        <TextBlock Text="{Binding LoadWatts}" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Bottom" Margin="0,0,0,6"/>
                      </StackPanel>
                    </StackPanel>
                    
                    <StackPanel Grid.Row="2" Grid.Column="2" Margin="0,0,0,12">
                      <TextBlock Text="TEMPERATURA INTERNA" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4"/>
                      <TextBlock Text="{Binding Temperature}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                    </StackPanel>

                    <!-- Battery Health Detail -->
                    <Border Grid.Row="3" Grid.ColumnSpan="3" Background="{StaticResource BgInputBrush}" CornerRadius="8" Padding="12" Margin="0,8,0,0">
                      <StackPanel>
                        <TextBlock Text="💚 SAÚDE DA BATERIA" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6"/>
                        <Grid>
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                          </Grid.ColumnDefinitions>
                          <TextBlock Grid.Column="0" Text="{Binding BatteryHealthText}" FontSize="18" FontWeight="Bold" Foreground="{Binding BatteryHealthBrush}" Margin="0,0,16,0"/>
                          <TextBlock Grid.Column="1" Text="{Binding BatteryHealthDetails}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" VerticalAlignment="Center"/>
                        </Grid>
                      </StackPanel>
                    </Border>
                  </Grid>
                </Border>
                
                <!-- Electrical Parameters -->
                <Border Style="{StaticResource CardStyle}">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                      <RowDefinition Height="Auto"/>
                      <RowDefinition Height="Auto"/>
                      <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Grid.ColumnSpan="3" Text="⚡ Parâmetros Elétricos" 
                               FontSize="15" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>
                    
                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,16,12">
                      <TextBlock Text="TENSÃO DE ENTRADA" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4"/>
                      <TextBlock Text="{Binding InputVoltage}" FontSize="32" FontWeight="Bold" Foreground="{StaticResource AccentBrush}"/>
                      <TextBlock Text="AC Input Voltage" FontSize="9" Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,16,12">
                      <TextBlock Text="TENSÃO DE SAÍDA" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4"/>
                      <TextBlock Text="{Binding OutputVoltage}" FontSize="32" FontWeight="Bold" Foreground="{StaticResource CyanBrush}"/>
                      <TextBlock Text="AC Output Voltage" FontSize="9" Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,12">
                      <TextBlock Text="FREQUÊNCIA DA REDE" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4"/>
                      <TextBlock Text="{Binding LineFreq}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                      <TextBlock Text="Line Frequency" FontSize="9" Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,16,12">
                      <TextBlock Text="QUALIDADE DA REDE" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4"/>
                      <TextBlock Text="{Binding VoltageStatus}" FontSize="16" FontWeight="SemiBold" Foreground="{Binding VoltageStatusBrush}"/>
                      <TextBlock Text="Voltage Quality Status" FontSize="9" Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,0,16,12">
                      <TextBlock Text="FAIXA NOMINAL" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4"/>
                      <TextBlock Text="{Binding VoltageRangeText}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                      <TextBlock Text="Acceptable Range" FontSize="9" Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Row="2" Grid.Column="2" Margin="0,0,0,12">
                      <TextBlock Text="FONTE DE ENERGIA" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4"/>
                      <TextBlock Text="{Binding PowerSourceText}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                      <TextBlock Text="Current Power Source" FontSize="9" Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                  </Grid>
                </Border>

                <!-- Power and Battery Details -->
                <Border Style="{StaticResource CardStyle}">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                      <RowDefinition Height="Auto"/>
                      <RowDefinition Height="Auto"/>
                      <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.ColumnSpan="3" Text="🔋 Potência e Bateria" 
                               FontSize="15" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>

                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,16,12">
                      <TextBlock Text="POTÊNCIA NOMINAL" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4"/>
                      <TextBlock Text="{Binding NominalPowerText}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                      <TextBlock Text="Rated Power" FontSize="9" Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,16,12">
                      <TextBlock Text="POTÊNCIA EM USO" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4"/>
                      <TextBlock Text="{Binding LoadWatts}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource AmberBrush}"/>
                      <TextBlock Text="Current Consumption" FontSize="9" Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,12">
                      <TextBlock Text="TEMPO EM BATERIA" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4"/>
                      <TextBlock Text="{Binding BatteryTimeInfo}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                      <TextBlock Text="Time on Battery Power" FontSize="9" Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,16,0">
                      <TextBlock Text="ÚLTIMA CARGA COMPLETA" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4"/>
                      <TextBlock Text="{Binding LastFullChargeInfo}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource GreenBrush}"/>
                      <TextBlock Text="Last Full Charge" FontSize="9" Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,0,16,0" Grid.ColumnSpan="2">
                      <TextBlock Text="ESTIMATIVA DE RECARGA" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4"/>
                      <TextBlock Text="{Binding ChargeEstimate}" FontSize="16" FontWeight="Bold" Foreground="{StaticResource GreenBrush}"/>
                      <TextBlock Text="{Binding ChargeRateText}" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                  </Grid>
                </Border>

                <!-- Device Identity & Communication -->
                <Border Style="{StaticResource CardStyle}">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                      <RowDefinition Height="Auto"/>
                      <RowDefinition Height="Auto"/>
                      <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.ColumnSpan="3" Text="💻 Identificação e Hardware" 
                               FontSize="15" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>

                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,16,12">
                      <TextBlock Text="MODELO DO UPS" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4"/>
                      <TextBlock Text="{Binding ModelAndSerial}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                      <TextBlock Text="Device Model &amp; Serial" FontSize="9" Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,16,12">
                      <TextBlock Text="VERSÃO DO FIRMWARE" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4"/>
                      <TextBlock Text="{Binding FirmwareVersion}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource AccentBrush}"/>
                      <TextBlock Text="Firmware / APCUPSD Version" FontSize="9" Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,12">
                      <TextBlock Text="DATA DE FABRICAÇÃO" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4"/>
                      <TextBlock Text="{Binding ManufactureDate}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                      <TextBlock Text="Manufacture Date" FontSize="9" Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,16,0">
                      <TextBlock Text="CONEXÃO NIS" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4"/>
                      <TextBlock Text="{Binding NisEndpoint}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource CyanBrush}" TextWrapping="Wrap"/>
                      <TextBlock Text="Network Interface Server" FontSize="9" Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,0,16,0">
                      <TextBlock Text="ÚLTIMA ATUALIZAÇÃO" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4"/>
                      <TextBlock Text="{Binding LastUpdateText}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                      <TextBlock Text="Last Data Refresh" FontSize="9" Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Row="2" Grid.Column="2" Margin="0,0,0,0">
                      <TextBlock Text="MODO DE OPERAÇÃO" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4"/>
                      <TextBlock Text="{Binding PowerSourceText}" FontSize="13" FontWeight="Bold" Foreground="{StaticResource GreenBrush}"/>
                      <TextBlock Text="Active Power Mode" FontSize="9" Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                  </Grid>
                </Border>
              </StackPanel>
            </ScrollViewer>
          </TabItem>
        </TabControl>
      </Grid>
    </Grid>
  </Border>
</Window>
