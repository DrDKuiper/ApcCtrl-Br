<Window x:Class="apctray2.AdvancedWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        Title="apcctrl - Dashboard Avançado" Height="720" Width="1200"
        MinHeight="600" MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        FontFamily="{StaticResource AppFont}">

  <Border Background="{StaticResource BgBaseBrush}" 
          CornerRadius="12" 
          BorderBrush="{StaticResource BorderSubtleBrush}" 
          BorderThickness="1">
    <Border.Effect>
      <DropShadowEffect Color="#000000" Direction="270" ShadowDepth="3" Opacity="0.5" BlurRadius="16"/>
    </Border.Effect>
    
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="40"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>

      <!-- Title Bar -->
      <Grid Grid.Row="0" Background="Transparent" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
        <StackPanel Orientation="Horizontal" Margin="16,0,0,0" VerticalAlignment="Center">
          <Ellipse Width="8" Height="8" Fill="{StaticResource CyanBrush}" Margin="0,0,8,0"/>
          <TextBlock Text="apcctrl" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
          <TextBlock Text="  Dashboard Avançado" FontSize="12" Foreground="{StaticResource TextMutedBrush}"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,8,0">
          <Button Content="&#x2500;" Style="{StaticResource TitleBarButton}" Click="Minimize_Click" FontFamily="Segoe UI" FontSize="14"/>
          <Button Content="&#x2715;" Style="{StaticResource CloseButton}" Click="CloseWindow_Click" FontFamily="Segoe UI" FontSize="12" Margin="4,0,0,0"/>
        </StackPanel>
      </Grid>

      <!-- Content -->
      <Grid Grid.Row="1" Margin="16,4,16,16">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header with mode indicator -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
          <StackPanel Orientation="Horizontal">
            <Border CornerRadius="10" Width="44" Height="44" Margin="0,0,12,0">
              <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                  <GradientStop Color="#22D3EE" Offset="0"/>
                  <GradientStop Color="#3B82F6" Offset="1"/>
                </LinearGradientBrush>
              </Border.Background>
              <TextBlock Text="&#x26A1;" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <StackPanel VerticalAlignment="Center">
              <TextBlock Text="{Binding UpsName}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
              <TextBlock Text="{Binding StatusFriendly}" FontSize="12" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold"/>
              <TextBlock Text="{Binding Status}" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
            </StackPanel>
          </StackPanel>
          
          <!-- Mode Badge -->
          <Border x:Name="ModeIndicator" HorizontalAlignment="Right" 
                  Background="{StaticResource GreenBrush}" CornerRadius="14" Padding="16,8">
            <StackPanel>
              <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="ModeIcon" Text="&#x1F50C;" FontSize="16" Margin="0,0,8,0"/>
                <TextBlock x:Name="ModeText" Text="MODO REDE" FontSize="14" FontWeight="Bold" Foreground="White"/>
              </StackPanel>
              <TextBlock x:Name="ModeSubText" Text="Atualizando..." FontSize="11" Foreground="#FFFFFFCC" Margin="0,2,0,0"/>
            </StackPanel>
          </Border>
        </Grid>

        <!-- Quick Stats Row -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>

          <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,4,0">
            <StackPanel>
              <TextBlock Text="Fonte de Energia" Style="{StaticResource MetricLabelStyle}"/>
              <TextBlock Text="{Binding PowerSourceText}" Style="{StaticResource MetricValueStyle}"/>
            </StackPanel>
          </Border>

          <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="4,0,4,0">
            <StackPanel>
              <TextBlock Text="Última Atualização" Style="{StaticResource MetricLabelStyle}"/>
              <TextBlock Text="{Binding LastUpdateText}" Style="{StaticResource MetricValueStyle}"/>
            </StackPanel>
          </Border>

          <Border Grid.Column="2" Style="{StaticResource CardStyle}" Margin="4,0,0,0">
            <StackPanel>
              <TextBlock Text="Qualidade Elétrica" Style="{StaticResource MetricLabelStyle}"/>
              <TextBlock Text="{Binding VoltageStatus}" Style="{StaticResource MetricValueStyle}" Foreground="{Binding VoltageStatusBrush}"/>
            </StackPanel>
          </Border>
        </Grid>

        <!-- Tabs -->
        <TabControl Grid.Row="2">
          <!-- Charts Tab -->
          <TabItem Header="&#x1F4CA; Gr&#xE1;ficos em Tempo Real">
            <Grid Background="Transparent" Margin="8">
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
              </Grid.RowDefinitions>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>

              <!-- Range Controls -->
              <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="8" HorizontalAlignment="Right">
                <TextBlock Text="&#x1F4C5; Range:" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,8,0"/>
                <ComboBox x:Name="RangeComboBox" Width="130" SelectedIndex="0" SelectionChanged="RangeComboBox_SelectionChanged">
                  <ComboBoxItem Content="1 hora"/>
                  <ComboBoxItem Content="6 horas"/>
                  <ComboBoxItem Content="24 horas"/>
                  <ComboBoxItem Content="Personalizado"/>
                </ComboBox>
                <DatePicker x:Name="StartDatePicker" Margin="8,0,4,0" Visibility="Collapsed" SelectedDateChanged="CustomRange_Changed"/>
                <TextBlock Text="até" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" Margin="4,0" Visibility="Collapsed" x:Name="DateSeparator"/>
                <DatePicker x:Name="EndDatePicker" Margin="4,0,0,0" Visibility="Collapsed" SelectedDateChanged="CustomRange_Changed"/>
              </StackPanel>

              <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource CardStyle}">
                <StackPanel>
                  <TextBlock Text="Carga da Bateria (%)" Style="{StaticResource CardTitleStyle}"/>
                  <lvc:CartesianChart x:Name="BatteryChart" Height="200"/>
                </StackPanel>
              </Border>

              <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource CardStyle}">
                <StackPanel>
                  <TextBlock Text="Carga do UPS (%)" Style="{StaticResource CardTitleStyle}"/>
                  <lvc:CartesianChart x:Name="LoadChart" Height="200"/>
                </StackPanel>
              </Border>

              <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource CardStyle}">
                <StackPanel>
                  <TextBlock Text="Tensão (V)" Style="{StaticResource CardTitleStyle}"/>
                  <lvc:CartesianChart x:Name="VoltageChart" Height="200"/>
                </StackPanel>
              </Border>

              <Border Grid.Row="2" Grid.Column="1" Style="{StaticResource CardStyle}">
                <StackPanel>
                  <TextBlock Text="Consumo (W)" Style="{StaticResource CardTitleStyle}"/>
                  <lvc:CartesianChart x:Name="WattsChart" Height="200"/>
                </StackPanel>
              </Border>
            </Grid>
          </TabItem>

          <!-- Log Tab -->
          <TabItem Header="&#x1F4CB; Log de Eventos">
            <Border Style="{StaticResource CardStyle}" Margin="8">
              <Grid>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="*"/>
                  <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <TextBlock Grid.Row="0" Text="Eventos Recentes" Style="{StaticResource CardTitleStyle}"/>
                
                <ListBox x:Name="LogList" Grid.Row="1" 
                         FontFamily="Consolas"
                         FontSize="11"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                  <Button Content="&#x21BB; Atualizar" Style="{StaticResource ModernButton}" Margin="0,0,8,0"/>
                  <Button Content="&#x2715; Limpar" Click="ClearLogs_Click" Style="{StaticResource ModernButton}"/>
                </StackPanel>
              </Grid>
            </Border>
          </TabItem>

          <!-- Technical Info Tab -->
          <TabItem Header="&#x1F527; Informa&#xE7;&#xF5;es T&#xE9;cnicas">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
              <StackPanel Margin="8">
                <Border Style="{StaticResource CardStyle}">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                      <RowDefinition Height="Auto"/>
                      <RowDefinition Height="Auto"/>
                      <RowDefinition Height="Auto"/>
                      <RowDefinition Height="Auto"/>
                      <RowDefinition Height="Auto"/>
                      <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Grid.ColumnSpan="3" Text="Métricas Detalhadas" 
                               Style="{StaticResource CardTitleStyle}" Margin="0,0,0,16"/>
                    
                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,12">
                      <TextBlock Text="Nome do UPS" Style="{StaticResource MetricLabelStyle}"/>
                      <TextBlock Text="{Binding UpsName}" Style="{StaticResource MetricValueStyle}"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,12">
                      <TextBlock Text="Status" Style="{StaticResource MetricLabelStyle}"/>
                      <TextBlock Text="{Binding StatusFriendly}" Style="{StaticResource MetricValueStyle}"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,12">
                      <TextBlock Text="Runtime" Style="{StaticResource MetricLabelStyle}"/>
                      <TextBlock Text="{Binding TimeLeft}" Style="{StaticResource MetricValueStyle}"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,0,12">
                      <TextBlock Text="Bateria" Style="{StaticResource MetricLabelStyle}"/>
                      <TextBlock Text="{Binding BatteryPercent, StringFormat='{}{0}%'}" FontSize="14" Foreground="{StaticResource GreenBrush}" FontWeight="Bold"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,0,0,12">
                      <TextBlock Text="Carga" Style="{StaticResource MetricLabelStyle}"/>
                      <TextBlock Text="{Binding LoadPercent, StringFormat='{}{0}%'}" FontSize="14" Foreground="{StaticResource AmberBrush}" FontWeight="Bold"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Row="2" Grid.Column="2" Margin="0,0,0,12">
                      <TextBlock Text="Consumo" Style="{StaticResource MetricLabelStyle}"/>
                      <TextBlock Text="{Binding LoadWatts}" Style="{StaticResource MetricValueStyle}"/>
                    </StackPanel>

                    <!-- Battery Health -->
                    <StackPanel Grid.Row="3" Grid.ColumnSpan="3" Margin="0,8,0,12">
                      <TextBlock Text="Saúde da Bateria" Style="{StaticResource MetricLabelStyle}"/>
                      <TextBlock Text="{Binding BatteryHealthText}" FontSize="14" FontWeight="SemiBold" Foreground="{Binding BatteryHealthBrush}"/>
                      <TextBlock Text="{Binding BatteryHealthDetails}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Row="4" Grid.Column="0" Margin="0,0,0,12">
                      <TextBlock Text="Tensão Entrada" Style="{StaticResource MetricLabelStyle}"/>
                      <TextBlock Text="{Binding InputVoltage}" Style="{StaticResource MetricValueStyle}"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Row="4" Grid.Column="1" Margin="0,0,0,12">
                      <TextBlock Text="Tensão Saída" Style="{StaticResource MetricLabelStyle}"/>
                      <TextBlock Text="{Binding OutputVoltage}" Style="{StaticResource MetricValueStyle}"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Row="4" Grid.Column="2" Margin="0,0,0,12">
                      <TextBlock Text="Frequência" Style="{StaticResource MetricLabelStyle}"/>
                      <TextBlock Text="{Binding LineFreq}" Style="{StaticResource MetricValueStyle}"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Row="5" Grid.Column="0" Margin="0,0,0,12">
                      <TextBlock Text="Temperatura" Style="{StaticResource MetricLabelStyle}"/>
                      <TextBlock Text="{Binding Temperature}" Style="{StaticResource MetricValueStyle}"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Row="5" Grid.Column="1" Margin="0,0,0,12">
                      <TextBlock Text="Status da Tensão" Style="{StaticResource MetricLabelStyle}"/>
                      <TextBlock Text="{Binding VoltageStatus}" Style="{StaticResource MetricValueStyle}" Foreground="{Binding VoltageStatusBrush}"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Row="5" Grid.Column="2" Margin="0,0,0,12">
                      <TextBlock Text="Tempo em Bateria" Style="{StaticResource MetricLabelStyle}"/>
                      <TextBlock Text="{Binding BatteryTimeInfo}" Style="{StaticResource MetricValueStyle}"/>
                    </StackPanel>
                  </Grid>
                </Border>

                <!-- Second card: Power Details -->
                <Border Style="{StaticResource CardStyle}">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                      <RowDefinition Height="Auto"/>
                      <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.ColumnSpan="3" Text="Potência e Recarga" Style="{StaticResource CardTitleStyle}"/>

                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,8">
                      <TextBlock Text="Potência Nominal" Style="{StaticResource MetricLabelStyle}"/>
                      <TextBlock Text="{Binding NominalPowerText}" Style="{StaticResource MetricValueStyle}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,8">
                      <TextBlock Text="Última Carga Completa" Style="{StaticResource MetricLabelStyle}"/>
                      <TextBlock Text="{Binding LastFullChargeInfo}" Style="{StaticResource MetricValueStyle}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,8">
                      <TextBlock Text="Range Ideal" Style="{StaticResource MetricLabelStyle}"/>
                      <TextBlock Text="{Binding VoltageRangeText}" Style="{StaticResource MetricValueStyle}"/>
                    </StackPanel>
                  </Grid>
                </Border>

                <!-- Third card: Identity -->
                <Border Style="{StaticResource CardStyle}">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                      <RowDefinition Height="Auto"/>
                      <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.ColumnSpan="3" Text="Identificação e Comunicação" Style="{StaticResource CardTitleStyle}"/>

                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,8">
                      <TextBlock Text="Modelo / Serial" Style="{StaticResource MetricLabelStyle}"/>
                      <TextBlock Text="{Binding ModelAndSerial}" Style="{StaticResource MetricValueStyle}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,8">
                      <TextBlock Text="Firmware" Style="{StaticResource MetricLabelStyle}"/>
                      <TextBlock Text="{Binding FirmwareVersion}" Style="{StaticResource MetricValueStyle}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,8">
                      <TextBlock Text="Endpoint NIS" Style="{StaticResource MetricLabelStyle}"/>
                      <TextBlock Text="{Binding NisEndpoint}" Style="{StaticResource MetricValueStyle}"/>
                    </StackPanel>
                  </Grid>
                </Border>
                
                <!-- Recharge Estimate -->
                <Border Style="{StaticResource CardStyle}">
                  <StackPanel>
                    <TextBlock Text="Estimativa de Recarga" Style="{StaticResource CardTitleStyle}"/>
                    <TextBlock Text="{Binding ChargeEstimate}" FontSize="16" Foreground="{StaticResource GreenBrush}" FontWeight="Bold"/>
                    <TextBlock Text="{Binding ChargeRateText}" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,6,0,0"/>
                  </StackPanel>
                </Border>
              </StackPanel>
            </ScrollViewer>
          </TabItem>
        </TabControl>
      </Grid>
    </Grid>
  </Border>
</Window>
