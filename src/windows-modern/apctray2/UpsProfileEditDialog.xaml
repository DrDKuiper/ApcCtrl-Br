<Window x:Class="apctray2.UpsProfileEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Perfil do Nobreak" Height="560" Width="540"
        MinHeight="500" MinWidth="500"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        ResizeMode="CanResize"
        FontFamily="{StaticResource AppFont}">

  <Border Background="{StaticResource BgBaseBrush}" 
          CornerRadius="16" 
          BorderBrush="{StaticResource BorderSubtleBrush}" 
          BorderThickness="1">
    <Border.Effect>
      <DropShadowEffect Color="#000000" Direction="270" ShadowDepth="3" Opacity="0.5" BlurRadius="16"/>
    </Border.Effect>
    
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="40"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>

      <!-- Title Bar -->
      <Grid Grid.Row="0" Background="Transparent" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
        <StackPanel Orientation="Horizontal" Margin="16,0,0,0" VerticalAlignment="Center">
          <Ellipse Width="8" Height="8" Fill="{StaticResource AccentBrush}" Margin="0,0,8,0"/>
          <TextBlock Text="Perfil do Nobreak" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
        </StackPanel>
        <Button Content="x" Style="{StaticResource CloseButton}" Click="CloseWindow_Click" FontFamily="Segoe UI" FontSize="12" HorizontalAlignment="Right" Margin="0,0,8,0"/>
      </Grid>

      <!-- Form -->
      <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="20,4,20,20">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>

          <!-- Name -->
          <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock Text="Nome do Nobreak:" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
            <TextBox x:Name="NameBox" Height="34"/>
          </StackPanel>

          <!-- Host -->
          <StackPanel Grid.Row="1" Margin="0,0,0,14">
            <TextBlock Text="Servidor (IP ou hostname):" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
            <TextBox x:Name="HostBox" Height="34"/>
          </StackPanel>

          <!-- Port -->
          <StackPanel Grid.Row="2" Margin="0,0,0,14">
            <TextBlock Text="Porta NIS:" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
            <TextBox x:Name="PortBox" Height="34" Text="3551"/>
          </StackPanel>

          <!-- Description -->
          <StackPanel Grid.Row="3" Margin="0,0,0,14">
            <TextBlock Text="Descricao (opcional):" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
            <TextBox x:Name="DescriptionBox" 
                     Height="60" 
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"/>
          </StackPanel>

          <!-- Tip -->
          <Border Grid.Row="4" Style="{StaticResource CardStyle}" BorderBrush="{StaticResource AmberBrush}" Margin="0,0,0,14">
            <StackPanel>
              <TextBlock Text="💡 Dica" FontWeight="Bold" Foreground="{StaticResource AmberBrush}" Margin="0,0,0,4"/>
              <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11">
                Configure o servidor NIS onde o apcctrl esta rodando. Para monitorar multiplos nobreaks, adicione um perfil para cada servidor.
              </TextBlock>
            </StackPanel>
          </Border>

          <!-- Buttons -->
          <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,0">
            <Button Content="Cancelar" 
                    IsCancel="True"
                    Width="100" Height="34"
                    Margin="0,0,8,0"
                    Style="{StaticResource ModernButton}"/>
            <Button Content="Salvar" 
                    Click="Save_Click"
                    Width="100" Height="34"
                    Style="{StaticResource SuccessButton}"/>
          </StackPanel>
        </Grid>
      </ScrollViewer>
    </Grid>
  </Border>
</Window>
